{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production-widget": {
      "autoIncrement": true,
      "env": {
        "EXPO_ENABLE_SCHEDULE_WIDGET": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_ENABLE_SCHEDULE_WIDGET": "0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
